generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Shared tables (match integrated-allergy IMS schema exactly) ───────────────

model Location {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  suite     String?
  street    String
  city      String
  state     String
  zip       String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  dates     LocationDate[]
}

model LocationDate {
  id         String   @id @default(cuid())
  locationId String
  type       String
  date       DateTime
  notes      String?
  createdAt  DateTime @default(now())
  location   Location @relation(fields: [locationId], references: [id])
}

model Doctor {
  id            String    @id @default(cuid())
  name          String
  title         String    @default("MD")
  specialty     String    @default("Allergy & Immunology")
  email         String?
  phone         String?
  clinicLocation String?
  npi           String?
  photoUrl      String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  entityId      String?
  appUserId     String?
  patients      Patient[]
  dates         DoctorDate[]
}

model DoctorDate {
  id        String   @id @default(cuid())
  doctorId  String
  type      String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
}

model Nurse {
  id            String    @id @default(cuid())
  name          String
  title         String    @default("RN")
  email         String?
  phone         String?
  clinicLocation String?
  npi           String?
  photoUrl      String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  entityId      String?
  appUserId     String?
}

// Patient — matches IMS schema but with IAT-specific date relations
model Patient {
  id               String    @id @default(cuid())
  patientId        String    @unique
  name             String
  dob              DateTime
  physician        String    @default("")
  clinicLocation   String    @default("")
  diagnosis        String    @default("")
  startDate        DateTime  @default(now())
  phone            String?
  homePhone        String?
  email            String?
  street           String?
  apt              String?
  city             String?
  state            String?
  zip              String?
  insuranceId      String?
  insuranceProvider String?
  insuranceGroup   String?
  emergencyName    String?
  emergencyPhone   String?
  emergencyRelation String?
  notes            String?
  status           String    @default("build-up")
  icd10Code        String?   // primary diagnosis ICD-10 code
  cptCodes         String?   // common CPT codes as JSON array
  doctorId        String?
  entityId        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  doctor          Doctor?   @relation(fields: [doctorId], references: [id])

  dates           PatientDate[]
  testResults     AllergyTestResult[]
  videoActivity   VideoActivity[]
  formActivity    FormActivity[]
  auditLogs       AuditLog[]
  consentRecords  ConsentRecord[]

  @@index([dob])
  @@index([deletedAt])
  @@index([status])
}

model PatientDate {
  id        String   @id @default(cuid())
  patientId String
  type      String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id])
}

// Allergen — matches IMS schema (no category column in shared table)
model Allergen {
  id           String    @id @default(cuid())
  name         String
  type         String    @default("other")
  manufacturer String    @default("")
  lotNumber    String?
  stockConc    String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  testResults  AllergyTestResult[]
}

model AllergyTestResult {
  id         String    @id @default(cuid())
  patientId  String
  allergenId String
  testType   String    // scratch | intradermal
  reaction   Int       @default(0)
  wheal      String?
  notes      String?
  nurseName  String?
  testedAt   DateTime  @default(now())
  readAt     DateTime?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  patient    Patient   @relation(fields: [patientId], references: [id])
  allergen   Allergen  @relation(fields: [allergenId], references: [id])
  dates      TestDate[]

  @@index([patientId])
  @@index([deletedAt])
  @@index([testedAt])
}

model TestDate {
  id        String   @id @default(cuid())
  testId    String
  type      String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  test      AllergyTestResult @relation(fields: [testId], references: [id])
}

model Video {
  id          String   @id @default(cuid())
  title       String
  description String?
  url         String
  duration    Int?
  category    String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  activity    VideoActivity[]
}

model VideoActivity {
  id           String   @id @default(cuid())
  patientId    String
  videoId      String
  watchedAt    DateTime @default(now())
  completed    Boolean  @default(false)
  acknowledged Boolean  @default(false)
  createdAt    DateTime @default(now())
  patient      Patient  @relation(fields: [patientId], references: [id])
  video        Video    @relation(fields: [videoId], references: [id])
}

model Form {
  id        String   @id @default(cuid())
  name      String
  type      String
  template  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  activity        FormActivity[]
  consentRecords  ConsentRecord[]
}

model FormActivity {
  id        String   @id @default(cuid())
  patientId String
  formId    String
  signedAt  DateTime?
  signature String?
  printedAt DateTime?
  emailedAt DateTime?
  pdfUrl    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  patient   Patient  @relation(fields: [patientId], references: [id])
  form      Form     @relation(fields: [formId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String   @default("")
  entityId  String?
  patientId String?
  details   String?
  createdAt DateTime @default(now())
  patient   Patient? @relation(fields: [patientId], references: [id])
}

model ConsentRecord {
  id          String   @id @default(cuid())
  patientId   String
  formId      String
  signedAt    DateTime @default(now())
  signature   String?
  pdfUrl      String?
  ipAddress   String?
  userAgent   String?
  version     String   @default("1.0")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  patient     Patient  @relation(fields: [patientId], references: [id])
  form        Form     @relation(fields: [formId], references: [id])
}

model WaitingRoom {
  id            String    @id @default(cuid())
  patientId     String
  patientName   String
  status        String    @default("waiting") // waiting | in-service | complete
  checkedInAt   DateTime  @default(now())
  calledAt      DateTime?
  completedAt   DateTime?
  nurseId       String?
  nurseName     String?
  notes         String?
  videosWatched Int       @default(0)
  videoAckBy    String?
  videoAckAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model StaffUser {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  name             String
  role             String    @default("staff")
  active           Boolean   @default(true)
  mfaEnabled       Boolean   @default(false)
  mfaSecret        String?
  tempToken        String?
  tempTokenExpiry  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model IATAppointment {
  id          String    @id @default(cuid())
  title       String
  patientId   String    // Required — must have a patient
  patientName String?
  reasonId    String?
  reasonName  String?
  startTime   DateTime
  endTime     DateTime
  type        String    @default("allergy-test")
  notes       String?
  status      String    @default("scheduled")
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([startTime])
  @@index([deletedAt])
  @@index([patientId])
}

model Encounter {
  id                  String    @id @default(cuid())
  patientId           String
  encounterDate       DateTime  @default(now())
  doctorId            String?
  doctorName          String?
  nurseId             String?
  nurseName           String?
  appointmentId       String?
  linkedAppointmentId String?
  chiefComplaint      String
  subjectiveNotes     String?
  objectiveNotes      String?
  assessment          String?
  plan                String?
  followUpDays        Int?
  status              String    @default("open")
  createdBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  activities          EncounterActivity[]

  @@index([patientId])
  @@index([encounterDate])
  @@index([deletedAt])
}

model EncounterActivity {
  id                  String    @id @default(cuid())
  encounterId         String
  patientId           String
  type                String    // kiosk_checkin | allergy_test | immunotherapy_shot | consent_signed | video_education | phone_call | email | in_person_visit | telehealth | appointment_scheduled | appointment_complete | lab_result | referral | prescription | no_show | note
  timestamp           DateTime  @default(now())
  performedBy         String?
  notes               String?
  subjectiveNotes     String?
  objectiveNotes      String?
  assessment          String?
  plan                String?
  linkedTestResultId  String?
  linkedConsentId     String?
  linkedAppointmentId String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  encounter           Encounter @relation(fields: [encounterId], references: [id])

  @@index([encounterId])
  @@index([patientId])
}

model AppointmentReason {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#0d9488")
  duration  Int      @default(30)
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model ICD10Code {
  id          String   @id @default(cuid())
  code        String   @unique
  description String
  category    String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model CPTCode {
  id          String   @id @default(cuid())
  code        String   @unique
  description String
  category    String?
  defaultFee  Float?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model EncounterActivityCode {
  id          String   @id @default(cuid())
  activityId  String
  codeType    String   // 'icd10' | 'cpt'
  code        String
  description String
  units       Int      @default(1)
  createdAt   DateTime @default(now())

  @@index([activityId])
}
