generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Shared tables (match integrated-allergy IMS schema exactly) ───────────────

model Practice {
  id        String     @id @default(cuid())
  name      String
  key       String?    @unique
  shortName String?
  phone     String?
  fax       String?
  email     String?
  website   String?
  npi       String?
  taxId     String?
  logoUrl   String?
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  locations Location[]
}

model Location {
  id         String    @id @default(cuid())
  name       String
  key        String    @unique
  suite      String?
  street     String
  city       String
  state      String
  zip        String
  phone      String?
  fax        String?
  email      String?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  practiceId String?
  practice   Practice? @relation(fields: [practiceId], references: [id])
  dates      LocationDate[]
}

model LocationDate {
  id         String   @id @default(cuid())
  locationId String
  type       String
  date       DateTime
  notes      String?
  createdAt  DateTime @default(now())
  location   Location @relation(fields: [locationId], references: [id])
}

model Doctor {
  id            String    @id @default(cuid())
  name          String
  title         String    @default("MD")
  specialty     String    @default("Allergy & Immunology")
  email         String?
  phone         String?
  clinicLocation String?
  npi           String?
  photoUrl      String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  entityId      String?
  appUserId     String?
  patients      Patient[]
  dates         DoctorDate[]
}

model DoctorDate {
  id        String   @id @default(cuid())
  doctorId  String
  type      String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
}

model Nurse {
  id            String    @id @default(cuid())
  name          String
  title         String    @default("RN")
  email         String?
  phone         String?
  clinicLocation String?
  npi           String?
  photoUrl      String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  entityId      String?
  appUserId     String?
}

// Patient — matches IMS schema but with IAT-specific date relations
model Patient {
  id               String    @id @default(cuid())
  patientId        String    @unique
  name             String
  dob              DateTime
  physician        String    @default("")
  clinicLocation   String    @default("")
  diagnosis        String    @default("")
  startDate        DateTime  @default(now())
  phone            String?
  homePhone        String?
  email            String?
  street           String?
  apt              String?
  city             String?
  state            String?
  zip              String?
  insuranceId      String?
  insuranceProvider String?
  insuranceGroup   String?
  emergencyName    String?
  emergencyPhone   String?
  emergencyRelation String?
  notes            String?
  status           String    @default("build-up")
  icd10Code        String?   // primary diagnosis ICD-10 code
  cptCodes         String?   // common CPT codes as JSON array
  doctorId        String?
  entityId        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  locationId      String    @default("loc-iat-001")

  doctor          Doctor?   @relation(fields: [doctorId], references: [id])

  dates           PatientDate[]
  testResults     AllergyTestResult[]
  videoActivity   VideoActivity[]
  formActivity    FormActivity[]
  auditLogs       AuditLog[]
  consentRecords  ConsentRecord[]
  maintenanceVials MaintenanceVial[]

  @@index([dob])
  @@index([deletedAt])
  @@index([status])
  @@index([locationId])
}

model PatientDate {
  id        String   @id @default(cuid())
  patientId String
  type      String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id])
}

// Allergen — matches IMS schema (no category column in shared table)
model Allergen {
  id                   String    @id @default(cuid())
  name                 String
  type                 String    @default("other")
  manufacturer         String    @default("")
  lotNumber            String?
  stockConc            String?
  expiresAt            DateTime?
  showOnTestingScreen   Boolean   @default(false)
  showOnPrickTest       Boolean   @default(false)
  showOnIntradermalTest Boolean   @default(false)
  createdAt             DateTime  @default(now())
  deletedAt            DateTime?

  testResults  AllergyTestResult[]
}

model AllergyTestResult {
  id         String    @id @default(cuid())
  patientId  String
  allergenId String
  testType   String    // scratch | intradermal
  reaction   Int       @default(0)
  wheal      String?
  notes      String?
  nurseName  String?
  testedAt   DateTime  @default(now())
  readAt     DateTime?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  patient    Patient   @relation(fields: [patientId], references: [id])
  allergen   Allergen  @relation(fields: [allergenId], references: [id])
  dates      TestDate[]

  @@index([patientId])
  @@index([deletedAt])
  @@index([testedAt])
}

model TestDate {
  id        String   @id @default(cuid())
  testId    String
  type      String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  test      AllergyTestResult @relation(fields: [testId], references: [id])
}

model Video {
  id          String   @id @default(cuid())
  title       String
  description String?
  url         String
  duration    Int?
  category    String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  activity    VideoActivity[]
}

model VideoActivity {
  id           String   @id @default(cuid())
  patientId    String
  videoId      String
  watchedAt    DateTime @default(now())
  completed    Boolean  @default(false)
  acknowledged Boolean  @default(false)
  createdAt    DateTime @default(now())
  patient      Patient  @relation(fields: [patientId], references: [id])
  video        Video    @relation(fields: [videoId], references: [id])
}

model Form {
  id        String   @id @default(cuid())
  name      String
  type      String
  template  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  activity        FormActivity[]
  consentRecords  ConsentRecord[]
}

model FormActivity {
  id        String   @id @default(cuid())
  patientId String
  formId    String
  signedAt  DateTime?
  signature String?
  printedAt DateTime?
  emailedAt DateTime?
  pdfUrl    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  patient   Patient  @relation(fields: [patientId], references: [id])
  form      Form     @relation(fields: [formId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entity      String   @default("")
  entityId    String?
  patientId   String?
  performedBy String?  // Name of the staff user who performed the action
  details     String?
  createdAt   DateTime @default(now())
  patient     Patient? @relation(fields: [patientId], references: [id])

  @@index([action])
  @@index([entityId])
  @@index([patientId])
  @@index([createdAt])
}

model ConsentRecord {
  id          String   @id @default(cuid())
  patientId   String
  formId      String
  signedAt    DateTime @default(now())
  signature   String?
  pdfUrl      String?
  ipAddress   String?
  userAgent   String?
  version     String   @default("1.0")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  patient     Patient  @relation(fields: [patientId], references: [id])
  form        Form     @relation(fields: [formId], references: [id])
}

model WaitingRoom {
  id            String    @id @default(cuid())
  patientId     String
  patientName   String
  status        String    @default("waiting") // waiting | in-service | complete
  checkedInAt   DateTime  @default(now())
  calledAt      DateTime?
  completedAt   DateTime?
  nurseId       String?
  nurseName     String?
  notes         String?
  videosWatched Int       @default(0)
  videoAckBy    String?
  videoAckAt    DateTime?
  locationId    String    @default("loc-iat-001")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([locationId])
}

model StaffUser {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  name              String
  role              String    @default("staff")
  permissions       String?   // JSON: { "permission_key": true/false } overrides
  active            Boolean   @default(true)
  mfaEnabled        Boolean   @default(false)
  mfaSecret         String?
  tempToken         String?
  tempTokenExpiry   DateTime?
  defaultLocationId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model IATAppointment {
  id          String    @id @default(cuid())
  title       String
  patientId   String    // Required — must have a patient
  patientName String?
  reasonId    String?
  reasonName  String?
  startTime   DateTime
  endTime     DateTime
  type        String    @default("allergy-test")
  notes       String?
  status      String    @default("scheduled")
  createdBy   String?
  locationId  String    @default("loc-iat-001")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([startTime])
  @@index([deletedAt])
  @@index([patientId])
  @@index([locationId])
}

model UserLocationAccess {
  id         String   @id @default(cuid())
  userId     String
  locationId String
  createdAt  DateTime @default(now())

  @@unique([userId, locationId])
  @@index([userId])
}

model Encounter {
  id                  String    @id @default(cuid())
  patientId           String
  encounterDate       DateTime  @default(now())
  doctorId            String?
  doctorName          String?
  nurseId             String?
  nurseName           String?
  appointmentId       String?
  linkedAppointmentId String?
  chiefComplaint      String
  subjectiveNotes     String?
  objectiveNotes      String?
  assessment          String?
  plan                String?
  followUpDays        Int?
  status              String    @default("open") // open | awaiting_md | signed | billed
  createdBy           String?
  waitMinutes         Int?      // Minutes from check-in to nurse calling patient
  inServiceMinutes    Int?      // Minutes from nurse call to encounter complete
  waitingRoomId       String?   // Link back to WaitingRoom entry
  // MD sign-off + billing
  signedBy            String?   // MD name who signed
  signedAt            DateTime? // When MD signed
  billedAt            DateTime? // When submitted to insurance
  mdAttestation       String?   // MD attestation text
  cptSummary          String?   // JSON: [{code, units, fee, description}]
  diagnosisCode       String?   // Primary ICD-10 for billing
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  locationId          String    @default("loc-iat-001")
  activities          EncounterActivity[]

  @@index([patientId])
  @@index([encounterDate])
  @@index([deletedAt])
  @@index([locationId])
}

model EncounterActivity {
  id                  String    @id @default(cuid())
  encounterId         String
  patientId           String
  type                String    // kiosk_checkin | allergy_test | immunotherapy_shot | consent_signed | video_education | phone_call | email | in_person_visit | telehealth | appointment_scheduled | appointment_complete | lab_result | referral | prescription | no_show | note
  timestamp           DateTime  @default(now())
  performedBy         String?
  notes               String?
  subjectiveNotes     String?
  objectiveNotes      String?
  assessment          String?
  plan                String?
  linkedTestResultId  String?
  linkedConsentId     String?
  linkedAppointmentId String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  encounter           Encounter @relation(fields: [encounterId], references: [id])

  @@index([encounterId])
  @@index([patientId])
}

model AppointmentReason {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#0d9488")
  duration  Int      @default(30)
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model MaintenanceVial {
  id              String    @id @default(cuid())
  patientId       String
  vialMode        String    @default("single")
  label           String    @default("Set A")
  currentDose     Float     @default(0.4)
  maxDose         Float     @default(0.5)
  concentration   String    @default("1:1")
  intervalWeeks   Int       @default(4)
  lastShotDate    DateTime?
  nextDueDate     DateTime?
  expiresAt       DateTime?
  active          Boolean   @default(true)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  patient         Patient   @relation(fields: [patientId], references: [id])
  shots           MaintenanceShot[]

  @@index([patientId])
}

model MaintenanceShot {
  id              String    @id @default(cuid())
  vialId          String
  patientId       String
  doseGiven       Float     @default(0.4)
  arm             String    @default("Left")
  reaction        Int       @default(0)
  reactionNotes   String?
  givenBy         String?
  givenAt         DateTime  @default(now())
  waitMinutes     Int       @default(30)
  createdAt       DateTime  @default(now())

  vial            MaintenanceVial @relation(fields: [vialId], references: [id])

  @@index([vialId])
  @@index([patientId])
  @@index([givenAt])
}

model ICD10Code {
  id          String   @id @default(cuid())
  code        String   @unique
  description String
  category    String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model CPTCode {
  id              String   @id @default(cuid())
  code            String   @unique
  description     String
  category        String?
  defaultFee      Float?   // clinic's own fee (editable)
  nonFacilityFee  Float?   // 2026 Medicare non-facility rate (read-only)
  facilityFee       Float?   // 2026 Medicare facility rate (read-only)
  maximumAllowable  Float?   // 2026 Medicare max allowable (locality-adjusted NoVA)
  active          Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
}

model EncounterActivityCode {
  id          String   @id @default(cuid())
  activityId  String
  codeType    String   // 'icd10' | 'cpt'
  code        String
  description String
  units       Int      @default(1)
  createdAt   DateTime @default(now())

  @@index([activityId])
}

model InsuranceCompany {
  id         String   @id @default(cuid())
  name       String
  type       String   @default("commercial") // medicare | medicaid | bcbs | commercial | tricare | aetna | united | cigna
  payerId    String?
  phone      String?
  fax        String?
  website    String?
  planTypes  String?  // comma-separated list
  notes      String?
  active     Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([type])
  @@index([active])
}

model PracticeInsurance {
  id          String   @id @default(cuid())
  practiceId  String
  insuranceId String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([practiceId, insuranceId])
  @@index([practiceId])
}

model PracticeHours {
  id           String  @id @default(cuid())
  practiceId   String
  dayOfWeek    Int     // 0=Sunday, 1=Monday ... 6=Saturday
  isOpen       Boolean @default(true)
  openTime     String  @default("08:00")  // HH:MM 24hr
  closeTime    String  @default("17:00")
  lunchStart   String? // HH:MM 24hr, null = no lunch break
  lunchEnd     String? // HH:MM 24hr
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([practiceId, dayOfWeek])
  @@index([practiceId])
}

model BillingRule {
  id                    String   @id @default(cuid())
  name                  String
  description           String?
  insuranceType         String   // all | medicare | medicaid | bcbs | commercial | tricare | aetna | united | cigna
  ruleType              String   // same_day_conflict | requires_modifier | max_units | lifetime_limit | dx_required | prior_auth | specialist_required | supervision | documentation | unbundling | in_person_required
  cptCode               String?
  relatedCptCode        String?
  maxUnits              Int?
  requiresModifier      String?
  requiresDxMatch       Boolean  @default(false)
  warningMessage        String
  severity              String   @default("warning") // warning | hard_block | info
  overrideRequiresAdmin Boolean  @default(false)
  active                Boolean  @default(true)
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([insuranceType])
  @@index([active])
  @@index([severity])
}
