generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Shared tables (match integrated-allergy IMS schema exactly) ───────────────

model Location {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  suite     String?
  street    String
  city      String
  state     String
  zip       String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  dates     LocationDate[]
}

model LocationDate {
  id         String   @id @default(cuid())
  locationId String
  type       String
  date       DateTime
  notes      String?
  createdAt  DateTime @default(now())
  location   Location @relation(fields: [locationId], references: [id])
}

model Doctor {
  id            String    @id @default(cuid())
  name          String
  title         String    @default("MD")
  specialty     String    @default("Allergy & Immunology")
  email         String?
  phone         String?
  clinicLocation String?
  npi           String?
  photoUrl      String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  entityId      String?
  appUserId     String?
  patients      Patient[]
  dates         DoctorDate[]
}

model DoctorDate {
  id        String   @id @default(cuid())
  doctorId  String
  type      String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
}

model Nurse {
  id            String    @id @default(cuid())
  name          String
  title         String    @default("RN")
  email         String?
  phone         String?
  clinicLocation String?
  npi           String?
  photoUrl      String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  entityId      String?
  appUserId     String?
}

// Patient — matches IMS schema but with IAT-specific date relations
model Patient {
  id              String    @id @default(cuid())
  patientId       String    @unique
  name            String
  dob             DateTime
  physician       String    @default("")
  clinicLocation  String    @default("")
  diagnosis       String    @default("")
  startDate       DateTime  @default(now())
  phone           String?
  email           String?
  insuranceId     String?
  notes           String?
  status          String    @default("build-up")
  doctorId        String?
  entityId        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  doctor          Doctor?   @relation(fields: [doctorId], references: [id])

  dates           PatientDate[]
  testResults     AllergyTestResult[]
  videoActivity   VideoActivity[]
  formActivity    FormActivity[]
  auditLogs       AuditLog[]
}

model PatientDate {
  id        String   @id @default(cuid())
  patientId String
  type      String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id])
}

// Allergen — matches IMS schema (no category column in shared table)
model Allergen {
  id           String    @id @default(cuid())
  name         String
  type         String    @default("other")
  manufacturer String    @default("")
  lotNumber    String?
  stockConc    String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  testResults  AllergyTestResult[]
}

model AllergyTestResult {
  id         String    @id @default(cuid())
  patientId  String
  allergenId String
  testType   String    // scratch | intradermal
  reaction   Int       @default(0)
  wheal      String?
  notes      String?
  testedAt   DateTime  @default(now())
  readAt     DateTime?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  patient    Patient   @relation(fields: [patientId], references: [id])
  allergen   Allergen  @relation(fields: [allergenId], references: [id])
  dates      TestDate[]
}

model TestDate {
  id        String   @id @default(cuid())
  testId    String
  type      String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  test      AllergyTestResult @relation(fields: [testId], references: [id])
}

model Video {
  id          String   @id @default(cuid())
  title       String
  description String?
  url         String
  duration    Int?
  category    String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  activity    VideoActivity[]
}

model VideoActivity {
  id           String   @id @default(cuid())
  patientId    String
  videoId      String
  watchedAt    DateTime @default(now())
  completed    Boolean  @default(false)
  acknowledged Boolean  @default(false)
  createdAt    DateTime @default(now())
  patient      Patient  @relation(fields: [patientId], references: [id])
  video        Video    @relation(fields: [videoId], references: [id])
}

model Form {
  id        String   @id @default(cuid())
  name      String
  type      String
  template  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  activity  FormActivity[]
}

model FormActivity {
  id        String   @id @default(cuid())
  patientId String
  formId    String
  signedAt  DateTime?
  signature String?
  printedAt DateTime?
  emailedAt DateTime?
  pdfUrl    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  patient   Patient  @relation(fields: [patientId], references: [id])
  form      Form     @relation(fields: [formId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String   @default("")
  entityId  String?
  patientId String?
  details   String?
  createdAt DateTime @default(now())
  patient   Patient? @relation(fields: [patientId], references: [id])
}

model StaffUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("staff")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
